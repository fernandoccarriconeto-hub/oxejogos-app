[{"pergunta": "Qual é o elemento mais abundante do universo?", "alternativas": ["A) Hélio", "B) Oxigênio", "C) Hidrogênio", "D) Ferro"], "resposta_correta": "C) Hidrogênio", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a velocidade da luz?", "alternativas": ["A) 150.000 km/s", "B) 200.000 km/s", "C) 300.000 km/s", "D) 400.000 km/s"], "resposta_correta": "C) 300.000 km/s", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a força fundamental mais forte?", "alternativas": ["A) Força eletromagnética", "B) Força nuclear forte", "C) Força nuclear fraca", "D) Gravidade"], "resposta_correta": "B) Força nuclear forte", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de força?", "alternativas": ["A) Joule", "B) Newton", "C) Pascal", "D) Watt"], "resposta_correta": "B) Newton", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a fórmula da energia cinética?", "alternativas": ["A) E = mc²", "B) E = ½mv²", "C) E = mgh", "D) E = qV"], "resposta_correta": "B) E = ½mv²", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é o número de Avogadro?", "alternativas": ["A) 6,02 × 10²²", "B) 6,02 × 10²³", "C) 6,02 × 10²⁴", "D) 6,02 × 10²⁵"], "resposta_correta": "B) 6,02 × 10²³", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a constante gravitacional (G)?", "alternativas": ["A) 6,67 × 10⁻¹⁰ N⋅m²/kg²", "B) 6,67 × 10⁻¹¹ N⋅m²/kg²", "C) 6,67 × 10⁻¹² N⋅m²/kg²", "D) 6,67 × 10⁻¹³ N⋅m²/kg²"], "resposta_correta": "B) 6,67 × 10⁻¹¹ N⋅m²/kg²", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a segunda lei de Newton?", "alternativas": ["A) F = G(m₁m₂)/r²", "B) F = ma", "C) F = kx", "D) F = μN"], "resposta_correta": "B) F = ma", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de pressão?", "alternativas": ["A) Newton", "B) Joule", "C) Pascal", "D) Watt"], "resposta_correta": "C) Pascal", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é o ponto de ebulição da água em Celsius?", "alternativas": ["A) 50°C", "B) 75°C", "C) 100°C", "D) 150°C"], "resposta_correta": "C) 100°C", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a carga elementar (e)?", "alternativas": ["A) 1,6 × 10⁻¹⁸ C", "B) 1,6 × 10⁻¹⁹ C", "C) 1,6 × 10⁻²⁰ C", "D) 1,6 × 10⁻²¹ C"], "resposta_correta": "B) 1,6 × 10⁻¹⁹ C", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de energia?", "alternativas": ["A) Newton", "B) Joule", "C) Pascal", "D) Coulomb"], "resposta_correta": "B) Joule", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a velocidade do som no ar (aproximadamente)?", "alternativas": ["A) 100 m/s", "B) 300 m/s", "C) 340 m/s", "D) 500 m/s"], "resposta_correta": "C) 340 m/s", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a lei de conservação de energia?", "alternativas": ["A) A energia não pode ser criada nem destruída", "B) A energia sempre aumenta", "C) A energia sempre diminui", "D) A energia é constante por unidade de tempo"], "resposta_correta": "A) A energia não pode ser criada nem destruída", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de potência?", "alternativas": ["A) Joule", "B) Newton", "C) Watt", "D) Pascal"], "resposta_correta": "C) Watt", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é o ponto de congelamento da água em Celsius?", "alternativas": ["A) -50°C", "B) 0°C", "C) 32°C", "D) 100°C"], "resposta_correta": "B) 0°C", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a massa do elétron (aproximadamente)?", "alternativas": ["A) 9,1 × 10⁻³¹ kg", "B) 9,1 × 10⁻²⁹ kg", "C) 9,1 × 10⁻²⁷ kg", "D) 9,1 × 10⁻²⁵ kg"], "resposta_correta": "A) 9,1 × 10⁻³¹ kg", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de frequência?", "alternativas": ["A) Metro", "B) Segundo", "C) Hertz", "D) Joule"], "resposta_correta": "C) Hertz", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a primeira lei de Newton?", "alternativas": ["A) Um corpo em repouso permanece em repouso, e um corpo em movimento permanece em movimento", "B) Força é igual à massa vezes aceleração", "C) Ação e reação são iguais e opostas", "D) Energia não pode ser criada nem destruída"], "resposta_correta": "A) Um corpo em repouso permanece em repouso, e um corpo em movimento permanece em movimento", "categoria": "Física", "dificuldade": "facim"}, {"pergunta": "Qual é a unidade SI de resistência elétrica?", "alternativas": ["A) Ampere", "B) Volt", "C) Ohm", "D) Coulomb"], "resposta_correta": "C) Ohm", "categoria": "Física", "dificuldade": "facim"}]